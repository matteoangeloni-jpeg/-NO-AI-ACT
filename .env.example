# Analytics privacy-by-design — vedi docs/ANALYTICS.md
# Default: console in sviluppo, OFF in produzione. Nessun dato personale.

# Valori: off | console | plausible | umami
VITE_ANALYTICS_PROVIDER=off

# Solo per provider=plausible
VITE_PLAUSIBLE_DOMAIN=

# Solo per provider=umami
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SCRIPT_URL=
