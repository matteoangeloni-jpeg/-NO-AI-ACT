{
  "name": "no-ai-act",
  "private": true,
  "version": "2.0.0",
  "description": "NO AI ACT — Simulatore di una società non regolata. Serious game investigativo sull'AI Act europeo.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build && node scripts/copy-notices.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "audit:seo": "node scripts/seo/audit-routes.mjs",
    "verify:dist": "node scripts/ci/verify-dist.mjs",
    "report:dist": "node scripts/ci/dist-report.mjs",
    "smoke:gameplay": "node scripts/smoke/gameplay-smoke.mjs",
    "smoke:keyboard": "node scripts/smoke/keyboard-smoke.mjs",
    "smoke:layout": "node scripts/smoke/layout-smoke.mjs",
    "smoke:all": "node scripts/smoke/run-all.mjs"
  },
  "license": "(MIT AND CC-BY-4.0)",
  "dependencies": {
    "phaser": "^3.87.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
